<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.fra.securitycheck</string>

  <key>ProgramArguments</key>
  <array>
    <string>__BASE_DIR__/bin/maccheck-alert</string>
  </array>

  <key>WorkingDirectory</key>
  <string>__BASE_DIR__</string>

  <key>RunAtLoad</key>
  <true/>

  <key>StartInterval</key>
  <integer>3600</integer>

  <key>StandardOutPath</key>
  <string>__HOME_DIR__/Library/Logs/mac-security-monitor.log</string>

  <key>StandardErrorPath</key>
  <string>__HOME_DIR__/Library/Logs/mac-security-monitor.err.log</string>

  <key>ProcessType</key>
  <string>Background</string>
</dict>
</plist>
