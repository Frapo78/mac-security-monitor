#!/bin/zsh

# Mac Security Monitor CLI dispatcher
# Author: Francesco Poltero

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=src/lib/common.sh
source "$SCRIPT_DIR/lib/common.sh"

COMMANDS_DIR="$SCRIPT_DIR/commands"
cmd="${1:-status}"

if [[ "$cmd" == "--version" || "$cmd" == "-v" ]]; then
  exec "$COMMANDS_DIR/version.sh"
fi

case "$cmd" in
  status)
    exec "$COMMANDS_DIR/status.sh"
    ;;
  log)
    exec "$COMMANDS_DIR/log.sh"
    ;;
  last-change)
    exec "$COMMANDS_DIR/last-change.sh"
    ;;
  update-baseline)
    exec "$COMMANDS_DIR/update-baseline.sh"
    ;;
  check-update)
    shift
    exec "$COMMANDS_DIR/check-update.sh" "$@"
    ;;
  upgrade)
    shift
    exec "$COMMANDS_DIR/upgrade.sh" "$@"
    ;;
  reinstall)
    shift
    exec "$COMMANDS_DIR/reinstall.sh" "$@"
    ;;
  report)
    exec "$COMMANDS_DIR/report.sh"
    ;;
  audit)
    exec "$COMMANDS_DIR/audit.sh"
    ;;
  help|--help|-h)
    exec "$COMMANDS_DIR/help.sh"
    ;;
  *)
    print_error "Unknown command: $cmd"
    exec "$COMMANDS_DIR/help.sh"
    ;;
esac
