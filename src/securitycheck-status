#!/bin/zsh

# Mac Security Monitor
# Author: Francesco Poltero
#
# Prints installation and runtime status for quick diagnostics.

set -euo pipefail

BASE_DIR="${BASE_DIR:-$HOME/.mac-security-monitor}"
BIN_DIR="$BASE_DIR/bin"
BASELINE_FILE="$BASE_DIR/baseline/current"
VERSION_FILE="$BASE_DIR/VERSION"
LOG_FILE="$BASE_DIR/logs/monitor.log"
LAST_CHANGE_FILE="$BASE_DIR/state/last-change"
LAUNCH_AGENT_LABEL="com.fra.securitycheck"
LAUNCH_AGENT_PLIST="$HOME/Library/LaunchAgents/${LAUNCH_AGENT_LABEL}.plist"

read_version() {
  if [[ -f "$VERSION_FILE" ]]; then
    head -n 1 "$VERSION_FILE"
  else
    echo "unknown"
  fi
}

print_last_change() {
  if [[ -f "$LAST_CHANGE_FILE" ]]; then
    cat "$LAST_CHANGE_FILE"
  else
    echo "No detected changes recorded yet."
  fi
}

print_log() {
  if [[ -f "$LOG_FILE" ]]; then
    tail -n 200 "$LOG_FILE"
  else
    echo "Log file not found: $LOG_FILE"
    exit 1
  fi
}

print_usage() {
  cat <<'USAGE'
Usage:
  security-monitor
  security-monitor --version
  security-monitor log
  security-monitor last-change
USAGE
}

case "${1:-}" in
  "" )
    ;;
  "--version"|"-v")
    echo "Mac Security Monitor $(read_version)"
    exit 0
    ;;
  "log")
    print_log
    exit 0
    ;;
  "last-change")
    print_last_change
    exit 0
    ;;
  "help"|"--help"|"-h")
    print_usage
    exit 0
    ;;
  *)
    echo "Unknown command: $1"
    print_usage
    exit 1
    ;;
esac

echo "=== Mac Security Monitor Status ==="
echo "Version: $(read_version)"

echo
echo "LaunchAgent registration:"
if launchctl list | grep -q "$LAUNCH_AGENT_LABEL"; then
  echo "Loaded: yes ($LAUNCH_AGENT_LABEL)"
else
  echo "Loaded: no"
fi

echo
echo "LaunchAgent file:"
if [[ -f "$LAUNCH_AGENT_PLIST" ]]; then
  echo "Present: yes"
else
  echo "Present: no"
fi

echo
echo "Baseline file:"
if [[ -f "$BASELINE_FILE" ]]; then
  echo "Present: yes"
  echo "Last modified: $(stat -f '%Sm' "$BASELINE_FILE")"
else
  echo "Present: no"
fi

echo
echo "Last detected change:"
print_last_change

echo
echo "Scripts:"
if [[ -x "$BIN_DIR/maccheck" ]]; then
  echo "maccheck: executable"
else
  echo "maccheck: missing or not executable"
fi

if [[ -x "$BIN_DIR/maccheck-alert" ]]; then
  echo "maccheck-alert: executable"
else
  echo "maccheck-alert: missing or not executable"
fi

echo
echo "maccheck sample output:"
if [[ -x "$BIN_DIR/maccheck" ]]; then
  "$BIN_DIR/maccheck" | head -n 5
else
  echo "Unavailable"
fi
