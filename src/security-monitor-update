#!/bin/zsh

# Mac Security Monitor
# Author: Francesco Poltero
#
# Updates the baseline and prints monitor status.

set -euo pipefail

BASE_DIR="${BASE_DIR:-$HOME/.mac-security-monitor}"
BIN_DIR="$BASE_DIR/bin"
BASELINE_DIR="$BASE_DIR/baseline"
BASELINE_FILE="$BASELINE_DIR/current"
LOG_DIR="$BASE_DIR/logs"
MONITOR_LOG="$LOG_DIR/monitor.log"
MSM_LOGGING="${MSM_LOGGING:-1}"

log_event() {
  local message="$1"

  if [[ "$MSM_LOGGING" == "0" ]]; then
    return 0
  fi

  mkdir -p "$LOG_DIR" 2>/dev/null || return 0
  printf '%s %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$message" >>"$MONITOR_LOG" 2>/dev/null || true
}

if [[ ! -x "$BIN_DIR/maccheck" ]]; then
  echo "[ERROR] maccheck not found or not executable: $BIN_DIR/maccheck"
  exit 1
fi

mkdir -p "$BASELINE_DIR"
"$BIN_DIR/maccheck" >"$BASELINE_FILE"
log_event "Baseline updated using security-monitor-update."

exec "$BIN_DIR/securitycheck-status" "$@"
