#!/bin/zsh

# Mac Security Monitor
# Author: Francesco Poltero
#
# Runs periodically from launchd, compares current state with baseline,
# shows a user dialog when changes are detected, and optionally checks
# for new versions once per day.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=src/lib/common.sh
source "$SCRIPT_DIR/lib/common.sh"

TMP_FILE="$(mktemp -t mac-security-monitor-current.XXXXXX)"

cleanup() {
  rm -f "$TMP_FILE"
}
trap cleanup EXIT

record_last_change() {
  safe_mkdir "$STATE_DIR" 2>/dev/null || return 0
  printf '%s\n' "Detected on $(date '+%Y-%m-%d %H:%M:%S')" >"$LAST_CHANGE_FILE" 2>/dev/null || true
}

notify() {
  local text="$1"
  osascript -e "display notification \"$text\" with title \"Mac Security Monitor\"" >/dev/null 2>&1 || true
}

prompt_critical_issues_action() {
  if ! command -v osascript >/dev/null 2>&1; then
    print_warn "osascript not available; keeping critical alerts active."
    touch "$CRITICAL_ALERT_ACTIVE_FILE" 2>/dev/null || true
    return 0
  fi

  local choice
  choice="$(osascript <<'OSA'
try
  display dialog "Mac Security Monitor detected critical security issues on this system.\n\nChoose how to proceed." buttons {"Show Details", "Keep Baseline Anyway", "Keep Alert Active"} default button "Keep Alert Active" with title "Mac Security Monitor"
  return button returned of result
on error
  return "Keep Alert Active"
end try
OSA
)"

  case "$choice" in
    "Show Details")
      if [[ -f "$CRITICAL_REPORT_FILE" ]]; then
        open -a TextEdit "$CRITICAL_REPORT_FILE" >/dev/null 2>&1 || true
      fi
      prompt_critical_issues_action
      ;;
    "Keep Baseline Anyway")
      rm -f "$FIRST_RUN_CHECK_FILE" "$CRITICAL_ALERT_ACTIVE_FILE" 2>/dev/null || true
      log_event "User accepted baseline despite critical issue warnings."
      notify "Baseline accepted despite critical warnings"
      ;;
    *)
      touch "$CRITICAL_ALERT_ACTIVE_FILE" 2>/dev/null || true
      rm -f "$FIRST_RUN_CHECK_FILE" 2>/dev/null || true
      log_event "Critical alert mode kept active by user."
      notify "Critical alert mode remains active"
      ;;
  esac
}

run_update_check_if_enabled() {
  if ! auto_update_check_enabled; then
    return 0
  fi

  if ! should_run_daily_update_check; then
    return 0
  fi

  touch "$LAST_UPDATE_CHECK_FILE" 2>/dev/null || true

  if [[ ! -x "$BIN_DIR/security-monitor" ]]; then
    log_event "WARN: update check requested but security-monitor is missing."
    return 0
  fi

  set +e
  "$BIN_DIR/security-monitor" check-update --quiet
  local rc=$?
  set -e

  case "$rc" in
    10)
      log_event "A newer version is available."
      notify "A new version of Mac Security Monitor is available."
      ;;
    0)
      log_event "Automatic update check: no new version available."
      ;;
    *)
      log_event "WARN: automatic update check failed with exit code $rc."
      ;;
  esac
}

run_critical_security_check() {
  if [[ ! -x "$BIN_DIR/commands/critical-check.sh" ]]; then
    log_event "WARN: critical-check.sh is missing."
    return 1
  fi

  set +e
  "$BIN_DIR/commands/critical-check.sh" --quiet
  local rc=$?
  set -e

  return "$rc"
}

if [[ ! -x "$BIN_DIR/maccheck" ]]; then
  log_event "ERROR: missing executable $BIN_DIR/maccheck"
  exit 1
fi

if [[ ! -f "$BASELINE_FILE" ]]; then
  log_event "ERROR: baseline not found at $BASELINE_FILE"
  exit 1
fi

if ! "$BIN_DIR/maccheck" >"$TMP_FILE"; then
  log_event "ERROR: failed to collect current system state"
  exit 1
fi

log_event "Monitor execution completed."
run_update_check_if_enabled

if [[ -f "$FIRST_RUN_CHECK_FILE" || -f "$CRITICAL_ALERT_ACTIVE_FILE" ]]; then
  if run_critical_security_check; then
    rm -f "$FIRST_RUN_CHECK_FILE" "$CRITICAL_ALERT_ACTIVE_FILE" 2>/dev/null || true
    log_event "Critical first-run security check passed."
  else
    rc=$?
    if [[ "$rc" -eq 20 ]]; then
      log_event "Critical issues detected during security check."
      prompt_critical_issues_action
    else
      log_event "WARN: critical security check failed with exit code $rc."
    fi
  fi
fi

if cmp -s "$BASELINE_FILE" "$TMP_FILE"; then
  log_event "No baseline changes detected."
  exit 0
fi

record_last_change
log_event "System changes detected against baseline."

BUTTON="$(osascript <<'OSA'
try
  display dialog "Mac Security Monitor detected system changes." buttons {"Help", "Show Details", "Update Baseline", "Disable Monitor"} default button "Show Details" with title "Mac Security Monitor"
  return button returned of result
on error
  return "Dismissed"
end try
OSA
)"

case "$BUTTON" in
  "Help")
    if [[ -f "$DOC_FILE" ]]; then
      open -a TextEdit "$DOC_FILE" >/dev/null 2>&1 || true
    fi
    ;;
  "Show Details")
    open -a TextEdit "$TMP_FILE" >/dev/null 2>&1 || true
    ;;
  "Update Baseline")
    cp -f "$TMP_FILE" "$BASELINE_FILE"
    log_event "Baseline updated from alert dialog."
    notify "Baseline updated successfully"
    ;;
  "Disable Monitor")
    launchctl bootout "gui/$(id -u)" "$LAUNCH_AGENT_PLIST" >/dev/null 2>&1 || true
    log_event "Monitoring disabled by user action."
    notify "Monitoring disabled"
    ;;
  *)
    log_event "Alert dismissed without action."
    ;;
esac
