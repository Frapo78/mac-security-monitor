#!/bin/zsh

# Mac Security Monitor
# Author: Francesco Poltero
#
# Runs periodically from launchd, compares current state with baseline,
# and shows a user dialog when changes are detected.

set -euo pipefail

BASE_DIR="${BASE_DIR:-$HOME/.mac-security-monitor}"
BIN_DIR="$BASE_DIR/bin"
BASELINE_FILE="$BASE_DIR/baseline/current"
DOC_FILE="$BASE_DIR/docs/README.md"
LOG_DIR="$BASE_DIR/logs"
STATE_DIR="$BASE_DIR/state"
MONITOR_LOG="$LOG_DIR/monitor.log"
LAST_CHANGE_FILE="$STATE_DIR/last-change"
LAUNCH_AGENT_LABEL="com.fra.securitycheck"
LAUNCH_AGENT_PLIST="$HOME/Library/LaunchAgents/${LAUNCH_AGENT_LABEL}.plist"
MSM_LOGGING="${MSM_LOGGING:-1}"
TMP_FILE="$(mktemp -t mac-security-monitor-current.XXXXXX)"

cleanup() {
  rm -f "$TMP_FILE"
}
trap cleanup EXIT

log_event() {
  local message="$1"

  if [[ "$MSM_LOGGING" == "0" ]]; then
    return 0
  fi

  mkdir -p "$LOG_DIR" 2>/dev/null || return 0
  printf '%s %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$message" >>"$MONITOR_LOG" 2>/dev/null || true
}

record_last_change() {
  mkdir -p "$STATE_DIR" 2>/dev/null || return 0
  printf '%s\n' "Detected on $(date '+%Y-%m-%d %H:%M:%S')" >"$LAST_CHANGE_FILE" 2>/dev/null || true
}

notify() {
  local text="$1"
  osascript -e "display notification \"$text\" with title \"Mac Security Monitor\"" >/dev/null 2>&1 || true
}

if [[ ! -x "$BIN_DIR/maccheck" ]]; then
  log_event "ERROR: missing executable $BIN_DIR/maccheck"
  exit 1
fi

if [[ ! -f "$BASELINE_FILE" ]]; then
  log_event "ERROR: baseline not found at $BASELINE_FILE"
  exit 1
fi

if ! "$BIN_DIR/maccheck" >"$TMP_FILE"; then
  log_event "ERROR: failed to collect current system state"
  exit 1
fi

log_event "Monitor execution completed."

if cmp -s "$BASELINE_FILE" "$TMP_FILE"; then
  log_event "No baseline changes detected."
  exit 0
fi

record_last_change
log_event "System changes detected against baseline."

BUTTON="$(osascript <<'OSA'
try
  display dialog "Mac Security Monitor detected system changes." buttons {"Help", "Show Details", "Update Baseline", "Disable Monitor"} default button "Show Details" with title "Mac Security Monitor"
  return button returned of result
on error
  return "Dismissed"
end try
OSA
)"

case "$BUTTON" in
  "Help")
    if [[ -f "$DOC_FILE" ]]; then
      open -a TextEdit "$DOC_FILE" >/dev/null 2>&1 || true
    fi
    ;;
  "Show Details")
    open -a TextEdit "$TMP_FILE" >/dev/null 2>&1 || true
    ;;
  "Update Baseline")
    cp -f "$TMP_FILE" "$BASELINE_FILE"
    log_event "Baseline updated from alert dialog."
    notify "Baseline updated successfully"
    ;;
  "Disable Monitor")
    launchctl bootout "gui/$(id -u)" "$LAUNCH_AGENT_PLIST" >/dev/null 2>&1 || true
    log_event "Monitoring disabled by user action."
    notify "Monitoring disabled"
    ;;
  *)
    log_event "Alert dismissed without action."
    ;;
esac
